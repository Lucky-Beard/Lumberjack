{
  "name": "@luckybeard/lumberjack",
  "version": "0.0.6",
  "private": false,
  "description": "A small structured logging helper for building wide, span-style log events.",
  "author": {
    "name": "Joshua Britz",
    "email": "joshua@luckybeard.com",
    "url": "https://www.luckybeard.com"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/cjs/index.js",
      "import": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "require": "./dist/cjs/testing/index.js",
      "import": "./dist/testing/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun run build.ts",
    "prepublishOnly": "bun run build",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "typecheck": "tsc --noEmit",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/chalk": "^2.2.4",
    "bun-plugin-dts": "^0.4.0",
    "chalk": "^5.6.2",
    "happy-dom": "^17.4.4",
    "oxfmt": "^0.38.0",
    "oxlint": "^1.53.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
