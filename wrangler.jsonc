{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "lumberjack",
  "compatibility_date": "2026-04-29",
  "workers_dev": true,
  "routes": [
    {
      "pattern": "lumberjack.luckybeard.com",
      "custom_domain": true,
    },
  ],
  "assets": {
    "directory": "./documentation/.vitepress/dist",
    "not_found_handling": "404-page",
  },
}
